{
  "name": "hellodownloader",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "postinstall": "pnpm run setup",
    "setup": "pnpm db:generate && pnpm --filter @hellodownloader/shared-types build && pnpm --filter @hellodownloader/config build && pnpm --filter @hellodownloader/auth-utils build && pnpm --filter @hellodownloader/queue-utils build && pnpm db:push",
    "dev": "turbo dev --filter=@hellodownloader/web --filter=@hellodownloader/api",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @hellodownloader/database exec prisma generate --schema=prisma/schema.prisma",
    "db:push": "pnpm --filter @hellodownloader/database exec prisma db push --schema=prisma/schema.prisma",
    "db:migrate": "pnpm --filter @hellodownloader/database db:migrate",
    "db:studio": "pnpm --filter @hellodownloader/database db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
