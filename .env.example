# App
NODE_ENV=development
PORT=4001
CORS_ORIGIN=http://localhost:3000
# Public site URL for payment success/cancel redirects (defaults to first CORS_ORIGIN)
# WEB_URL=https://hellodownloader.com
NEXT_PUBLIC_API_URL=http://localhost:4001/api/v1

# Database
# Local (SQLite, no Docker):
DATABASE_URL=file:./dev.db
# Production / Docker Postgres:
# DATABASE_URL=postgresql://hellodownloader:hellodownloader@localhost:5432/hellodownloader

# Redis (optional — disabled by default in dev; set USE_BULLMQ_DOWNLOADS=true in production)
REDIS_URL=redis://localhost:6379
# USE_BULLMQ_DOWNLOADS=true
# USE_BULLMQ_THUMBNAILS=true
# REDIS_ENABLED=true

# Google OAuth (Sign in with Google)
# Create credentials: https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000, https://yourdomain.com
# Optional: configure in Admin → Site Settings → Authentication instead of env vars.
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# JWT (generate secure random strings in production)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars!!
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32!!
JWT_REFRESH_EXPIRES_IN=30d

# Storage
STORAGE_PATH=./storage
FILE_RETENTION_HOURS=1
# Max stored AI thumbnail jobs per user (older ones auto-deleted)
THUMBNAIL_RETENTION_COUNT=10
# Keep files on disk until page refresh, new download, or retention expires (not on save click)
DELETE_FILE_AFTER_DOWNLOAD=false

# yt-dlp / FFmpeg
# macOS Homebrew: /opt/homebrew/bin/yt-dlp  |  Linux: /usr/local/bin/yt-dlp
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
# Optional: aria2c enables 16-connection parallel HTTP downloads (much faster)
# brew install aria2
# ARIA2C_PATH=/opt/homebrew/bin/aria2c
# YT_DLP_DOWNLOAD_TIMEOUT_MS=3600000
# Playlist exports default to 6 hours (override if needed)
# YT_DLP_PLAYLIST_TIMEOUT_MS=21600000
# YT_DLP_HTTP_CHUNK_SIZE=10M
# YT_DLP_ARIA2_CONNECTIONS=16
# Optional global style prompt for AI thumbnail generation (also editable in Admin → Thumbnails → AI Settings)
# THUMBNAIL_AI_GLOBAL_PROMPT=Bold YouTube style, high contrast, readable text

# AI providers (optional — import into Admin on first boot; prefer Admin UI in production)
# OPENAI_API_KEY=
# FAL_API_KEY=
# TEXT_PROVIDER=openai
# TEXT_MODEL=gpt-5-mini
# IMAGE_PROVIDER=fal
# BASIC_IMAGE_MODEL=flux-dev
# PRO_IMAGE_MODEL=flux-kontext-pro
# Export cookies from your browser (Netscape format) — helps with login-required content.
# YT_DLP_COOKIES_FILE=storage/cookies.txt
# Dev-only: browser cookies (triggers macOS Keychain — NOT for SaaS users)
# YT_DLP_COOKIES_FROM_BROWSER=chrome
# YT_DLP_ENABLE_BROWSER_COOKIES=true

# Cloudflare R2 (optional — configure in Admin → Storage or set env vars)
# Videos: short retention on R2 (~1h). Thumbnails: ~30 days. Env overrides admin when set.
# R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hellodownloader
R2_PUBLIC_URL=https://your-bucket.r2.dev

# App URLs (first origin used for payment redirects)
CORS_ORIGIN=http://localhost:3000
# Public site URL for payment success/cancel redirects (defaults to first CORS_ORIGIN)
# WEB_URL=https://hellodownloader.com
API_PUBLIC_URL=http://127.0.0.1:4001
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Binance Pay
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# SSLCommerz
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWD=
SSLCOMMERZ_IS_LIVE=false

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Pro plan
PRO_MONTHLY_CREDITS=100

# Ads (optional slot IDs)
AD_BANNER_SLOT=banner-1
AD_POPUP_SLOT=popup-1
AD_REWARDED_SLOT=rewarded-1

# Logging
LOG_LEVEL=info
