generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum PlanType {
  FREE
  PRO
}

enum DownloadStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum DownloadType {
  VIDEO
  PLAYLIST
  SHORTS
  REEL_FACEBOOK
  REEL_INSTAGRAM
  MP3
  SUBTITLE
  ZIP
}

enum ThumbnailStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ThumbnailRatio {
  YOUTUBE_16_9
  SHORTS_9_16
  INSTAGRAM_4_5
  FACEBOOK_1_1
}

enum PaymentProvider {
  STRIPE
  BINANCE
  SSLCOMMERZ
}

enum AiImageProvider {
  FAL
  OPENAI
  REPLICATE
  IDEOGRAM
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum ThumbnailPromptType {
  GLOBAL
  CATEGORY
  ADJUST
}

enum ThumbnailPromptStatus {
  ENABLED
  DISABLED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?   @map("password_hash")
  googleId      String?   @unique @map("google_id")
  name          String?
  role          UserRole  @default(USER)
  plan          PlanType  @default(FREE)
  credits       Int       @default(0)
  emailVerified Boolean   @default(false) @map("email_verified")
  avatarUrl     String?   @map("avatar_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  downloads      Download[]
  playlists      Playlist[]
  thumbnails     Thumbnail[]
  subscriptions  Subscription[]
  transactions   Transaction[]
  creditLogs     CreditLog[]
  payments       Payment[]
  analytics      Analytics[]
  fourKInterestSurvey FourKInterestSurvey?

  @@map("users")
}

model Download {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  url         String
  type        DownloadType
  status      DownloadStatus @default(PENDING)
  title       String?
  thumbnail   String?
  format      String?
  quality     Int?
  filePath    String?        @map("file_path")
  fileUrl     String?        @map("file_url")
  fileSize    BigInt?        @map("file_size")
  duration    Int?
  metadata    Json?
  error       String?
  progress    Int            @default(0)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  completedAt DateTime?      @map("completed_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist? @relation(fields: [playlistId], references: [id])
  playlistId String? @map("playlist_id")

  @@index([userId])
  @@index([status])
  @@map("downloads")
}

model Playlist {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  url         String
  title       String?
  status      DownloadStatus @default(PENDING)
  itemCount   Int            @default(0) @map("item_count")
  zipPath     String?        @map("zip_path")
  zipUrl      String?        @map("zip_url")
  progress    Int            @default(0)
  error       String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  completedAt DateTime?      @map("completed_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  downloads Download[]

  @@index([userId])
  @@map("playlists")
}

model Thumbnail {
  id           String          @id @default(cuid())
  userId       String          @map("user_id")
  videoUrl     String          @map("video_url")
  ratio        ThumbnailRatio
  status       ThumbnailStatus @default(PENDING)
  originalPath String?         @map("original_path")
  resizedPath  String?         @map("resized_path")
  exportPath   String?         @map("export_path")
  exportUrl    String?         @map("export_url")
  creditsUsed  Int             @default(0) @map("credits_used")
  ocrData      Json?           @map("ocr_data")
  error        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("thumbnails")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @map("user_id")
  plan                 PlanType           @default(PRO)
  status               SubscriptionStatus @default(ACTIVE)
  provider             PaymentProvider
  providerSubId        String?            @map("provider_sub_id")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  provider    PaymentProvider
  amount      Float
  currency    String          @default("USD")
  status      PaymentStatus   @default(PENDING)
  providerId  String?         @map("provider_id")
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("transactions")
}

model Payment {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  provider    PaymentProvider
  amount      Float
  currency    String          @default("USD")
  status      PaymentStatus   @default(PENDING)
  providerRef String?         @map("provider_ref")
  invoiceUrl  String?         @map("invoice_url")
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}

model CreditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  amount    Int
  reason    String
  balance   Int
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credit_logs")
}

model Analytics {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  event     String
  metadata  Json?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([event])
  @@index([userId])
  @@map("analytics")
}

model PaymentProviderConfig {
  provider  PaymentProvider @id
  enabled   Boolean         @default(false)
  mode      String          @default("TEST")
  amount    Float
  currency  String
  secrets   Json?           @map("secrets")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("payment_provider_configs")
}

model ContentPage {
  slug      String   @id
  title     String
  sections  Json?    @map("sections")
  published Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("content_pages")
}

model AiImageProviderConfig {
  provider  AiImageProvider @id
  enabled   Boolean         @default(false)
  priority  Int             @default(10)
  modelId   String          @default("") @map("model_id")
  secrets   Json?           @map("secrets")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("ai_image_provider_configs")
}

model ThumbnailAiSettings {
  id             Int      @id @default(1)
  globalPrompt   String   @default("") @map("global_prompt")
  enableFallback Boolean  @default(true) @map("enable_fallback")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("thumbnail_ai_settings")
}

model AiApiSettings {
  id                          Int       @id @default(1)
  textProvider                String    @default("openai") @map("text_provider")
  textModel                   String    @default("gpt-5-mini") @map("text_model")
  openaiApiKey                String    @default("") @map("openai_api_key")
  openaiConnectionStatus      String    @default("unknown") @map("openai_connection_status")
  openaiLastTestedAt          DateTime? @map("openai_last_tested_at")
  imageProvider               String    @default("fal") @map("image_provider")
  basicImageModel             String    @default("flux-dev") @map("basic_image_model")
  proImageModel               String    @default("flux-kontext-pro") @map("pro_image_model")
  falApiKey                   String    @default("") @map("fal_api_key")
  falConnectionStatus         String    @default("unknown") @map("fal_connection_status")
  falLastTestedAt             DateTime? @map("fal_last_tested_at")
  enableAiAnalysis            Boolean   @default(true) @map("enable_ai_analysis")
  enableAiThumbnailGeneration Boolean   @default(true) @map("enable_ai_thumbnail_generation")
  enableAiImproveThumbnail    Boolean   @default(true) @map("enable_ai_improve_thumbnail")
  enableAutoCategoryDetection Boolean   @default(true) @map("enable_auto_category_detection")
  enableThumbnailScoring      Boolean   @default(true) @map("enable_thumbnail_scoring")
  enableAutoLayoutDetection   Boolean   @default(true) @map("enable_auto_layout_detection")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  @@map("ai_api_settings")
}

model ThumbnailPrompt {
  id        String                @id @default(cuid())
  name      String
  slug      String                @unique
  type      ThumbnailPromptType
  content   String                @default("")
  status    ThumbnailPromptStatus @default(ENABLED)
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@map("thumbnail_prompts")
}

model SiteSettings {
  id                    Int      @id @default(1)
  siteName              String   @default("HelloDownloader") @map("site_name")
  siteUrl               String   @default("") @map("site_url")
  titleTemplate         String   @default("%s | HelloDownloader") @map("title_template")
  defaultMetaTitle      String   @default("") @map("default_meta_title")
  defaultMetaDescription String  @default("") @map("default_meta_description")
  defaultKeywords       String   @default("") @map("default_keywords")
  defaultOgImage        String   @default("") @map("default_og_image")
  faviconUrl            String   @default("") @map("favicon_url")
  globalHeadHtml          String   @default("") @map("global_head_html")
  globalHeadJs            String   @default("") @map("global_head_js")
  globalCss               String   @default("") @map("global_css")
  globalBodyJs            String   @default("") @map("global_body_js")
  googleSiteVerification  String   @default("") @map("google_site_verification")
  bingSiteVerification    String   @default("") @map("bing_site_verification")
  customHeadSnippet       String   @default("") @map("custom_head_snippet")
  verificationFiles       Json?    @map("verification_files")
  routeSeo                Json?    @map("route_seo")
  robotsDisallow          Json?    @map("robots_disallow")
  googleAuthEnabled       Boolean  @default(false) @map("google_auth_enabled")
  googleClientId          String   @default("") @map("google_client_id")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model StorageSettings {
  id                     Int      @id @default(1)
  r2Enabled              Boolean  @default(false) @map("r2_enabled")
  r2AccountId            String   @default("") @map("r2_account_id")
  r2AccessKeyId          String   @default("") @map("r2_access_key_id")
  r2SecretAccessKey      String   @default("") @map("r2_secret_access_key")
  r2BucketName           String   @default("hellodownloader") @map("r2_bucket_name")
  r2PublicUrl            String   @default("") @map("r2_public_url")
  videoRetentionHours    Int      @default(1) @map("video_retention_hours")
  thumbnailRetentionDays Int      @default(30) @map("thumbnail_retention_days")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("storage_settings")
}

model AdsSettings {
  id        Int      @id @default(1)
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ads_settings")
}

model FourKInterestSurvey {
  id         String   @id @default(cuid())
  interested Boolean  @map("interested")
  userId     String?  @unique @map("user_id")
  visitorId  String?  @unique @map("visitor_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("four_k_interest_surveys")
}
