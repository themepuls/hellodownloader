# Production .env for hellodownloader.com
# Copy to /var/www/hellodownloader/.env on the VPS

NODE_ENV=production
PORT=4001

# Site (browser) — comma-separated CORS origins for API
CORS_ORIGIN=https://hellodownloader.com,https://www.hellodownloader.com
WEB_URL=https://hellodownloader.com

# API subdomain (used by browser + download file URLs)
NEXT_PUBLIC_API_URL=https://api.hellodownloader.com/api/v1
API_PUBLIC_URL=https://api.hellodownloader.com

# Database
DATABASE_URL=postgresql://hellodownloader:CHANGE_ME_DB_PASSWORD@localhost:5432/hellodownloader

# Redis — inline downloads on API until workers are built (set true + build workers later)
REDIS_URL=redis://127.0.0.1:6379
USE_BULLMQ_DOWNLOADS=false
USE_BULLMQ_THUMBNAILS=false

# JWT — generate: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_48
JWT_REFRESH_SECRET=REPLACE_WITH_openssl_rand_base64_48
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

STORAGE_PATH=./storage
FILE_RETENTION_HOURS=1
DELETE_FILE_AFTER_DOWNLOAD=false

YT_DLP_PATH=/usr/local/bin/yt-dlp
FFMPEG_PATH=/usr/bin/ffmpeg

ADMIN_EMAIL=admin@hellodownloader.com
ADMIN_PASSWORD=Choose-A-Strong-Password-Here

LOG_LEVEL=info
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Google OAuth (Admin → Site Settings, or env)
# Authorized JS origins: https://hellodownloader.com, https://www.hellodownloader.com
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_ID=

# Payments (when ready)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=https://api.hellodownloader.com/api/v1/webhooks/stripe
# STRIPE_PRO_PRICE_ID=
