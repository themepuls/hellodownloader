# Copy to /var/www/hellodownloader/.env on the VPS
# Replace YOUR_DOMAIN and generate new JWT secrets (openssl rand -base64 48)

NODE_ENV=production
PORT=4001

# Public URLs — all must use https://YOUR_DOMAIN in production
CORS_ORIGIN=https://YOUR_DOMAIN
WEB_URL=https://YOUR_DOMAIN
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN/api/v1
API_PUBLIC_URL=https://YOUR_DOMAIN

# Database (match postgres user/db you create on VPS)
DATABASE_URL=postgresql://hellodownloader:CHANGE_ME_DB_PASSWORD@localhost:5432/hellodownloader

# Redis — optional for first deploy; set false to process downloads on API process
REDIS_URL=redis://127.0.0.1:6379
USE_BULLMQ_DOWNLOADS=false
USE_BULLMQ_THUMBNAILS=false

# JWT — REQUIRED: generate unique secrets (min 32 chars)
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_48
JWT_REFRESH_SECRET=REPLACE_WITH_openssl_rand_base64_48
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Storage on disk
STORAGE_PATH=./storage
FILE_RETENTION_HOURS=1
DELETE_FILE_AFTER_DOWNLOAD=false

# System tools (installed by setup script)
YT_DLP_PATH=/usr/bin/yt-dlp
FFMPEG_PATH=/usr/bin/ffmpeg

# Admin (used once: node scripts/create-admin.mjs)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=Choose-A-Strong-Password-Here

LOG_LEVEL=info
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
